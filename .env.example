POSTGRES_PASSWORD=changeme
DATABASE_URL=postgres://vidi:changeme@db:5432/vidi
VIDI_PUBLIC_URL=https://belgium-atmosphe.re/vidi
VIDI_TOKEN_ENC_KEY=<32-byte base64>
VIDI_COOKIE_SECRET=<32+ char secret>
VIDI_SUPERADMIN_DIDS=did:plc:xxxx
TRUSTED_VERIFIER_LIST_URIS=at://did:plc:ooensn4mr5mhznzypvxelfa3/app.bsky.graph.list/3mogaw2g4an23
# Comma-separated list of DIDs to add to the trusted verifier allowlist on first run (seed)
VIDI_SEED_ALLOWLIST=did:plc:xxxx,did:plc:yyyy
# Comma-separated list of keywords to crawl on first run (seed)
VIDI_SEED_KEYWORDS=keyword1,keyword2
# Confidential atproto OAuth client signing key (ES256 / P-256 JWK, JSON-encoded, includes private "d").
# Generate with:
#   node -e "require('jose').generateKeyPair('ES256',{extractable:true}).then(async({privateKey})=>console.log(JSON.stringify(await require('jose').exportJWK(privateKey))))"
# Keep this secret; only the derived public JWK is ever served (see GET /jwks.json).
# NOT required for local development: when VIDI_PUBLIC_URL points at
# 127.0.0.1/localhost/[::1], Vidi uses the atproto public loopback OAuth
# client instead (no keyset). See README "Local login (loopback)".
VIDI_OAUTH_PRIVATE_JWK={"kty":"EC","crv":"P-256","x":"...","y":"...","d":"..."}

# Public, unauthenticated atproto AppView used for app.bsky.* profile reads
# (e.g. resolving a subject's handle/displayName when not yet indexed
# locally). Avoids routing reads through a user's/org's OAuth-bound PDS,
# which can 401 on non-bsky.social PDS deployments. Default:
# https://public.api.bsky.app
VIDI_PUBLIC_APPVIEW_URL=https://public.api.bsky.app

# Typeahead search endpoint used by the keyword-seed crawler phase to
# discover candidate accounts from configured crawl-seed keywords. Default:
# https://typeahead.waow.tech
VIDI_TYPEAHEAD_URL=https://typeahead.waow.tech
